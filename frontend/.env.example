# API (required for data and sitemap)
NEXT_PUBLIC_API_URL=http://148.230.67.118:5000/api
NEXT_PUBLIC_SOCKET_URL=http://148.230.67.118:5000

# SEO – set in production for correct sitemap, OG, and canonical URLs
# Production example:
#   NEXT_PUBLIC_BASE_URL=https://yourdomain.com
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
# Must be set at BUILD time (sitemap/robots use them).
NEXT_PUBLIC_BASE_URL=http://148.230.67.118:3000

# Production: set to true to allow indexing. Set false on staging/dev to keep noindex.
NEXT_PUBLIC_SEO_INDEXABLE=true

# Optional: set to true in development to disable React StrictMode (reduces duplicate API calls from double mount)
# NEXT_PUBLIC_DISABLE_STRICT_MODE=true
