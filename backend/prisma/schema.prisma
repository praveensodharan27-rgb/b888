// MongoDB Prisma Schema
// This schema is compatible with MongoDB
// All models maintain the same field structure as PostgreSQL version

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                @id @default(auto()) @map("_id") @db.ObjectId
  email                   String?
  phone                   String?
  password                String?
  name                    String
  avatar                  String?
  bio                     String?
  tags                    String[]              @default([])
  showPhone               Boolean               @default(true)
  isVerified              Boolean               @default(false)
  role                    UserRole              @default(USER)
  freeAdsUsed             Int                   @default(0) // Historical tracking (lifetime)
  freeAdsRemaining        Int                   @default(2) // Monthly free ads remaining (resets monthly)
  freeAdsUsedThisMonth    Int                   @default(0) // Free ads used in current month
  lastFreeAdsResetDate    DateTime? // Last date when free ads were reset
  membershipActive        Boolean               @default(false)
  membershipType          String? // PREMIUM, BASIC, etc.
  membershipExpiresAt     DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  provider                String?
  providerId              String?
  referralCode            String?
  referredBy              String?               @db.ObjectId
  isDeactivated           Boolean               @default(false)
  deactivatedAt           DateTime?
  tokenInvalidatedAt      DateTime?
  locationId              String?               @db.ObjectId
  location                Location?             @relation(fields: [locationId], references: [id])
  ads                     Ad[]
  adPostingOrders         AdPostingOrder[]
  receivedMessages        ChatMessage[]         @relation("ReceiverMessages")
  sentMessages            ChatMessage[]         @relation("SenderMessages")
  chatRooms               ChatRoom[]            @relation("User1Rooms")
  chatRooms2              ChatRoom[]            @relation("User2Rooms")
  favorites               Favorite[]
  notifications           Notification[]
  otpCodes                OTP[]
  premiumOrders           PremiumOrder[]
  pushSubscriptions       PushSubscription[]
  referrals               Referral[]            @relation("Referrer")
  referredByUser          User?                 @relation("ReferredBy", fields: [referredBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referredUsers           User[]                @relation("ReferredBy")
  wallet                  Wallet?
  businessPackages        BusinessPackage[]
  userBusinessPackages    UserBusinessPackage[]
  extraAdSlots            ExtraAdSlot[]
  followers               Follow[]              @relation("Following")
  following               Follow[]              @relation("Follower")
  contactRequestsSent     ContactRequest[]      @relation("ContactRequester")
  contactRequestsReceived ContactRequest[]      @relation("ContactSeller")
  blockedUsers            Block[]               @relation("Blocker")
  blockedBy               Block[]               @relation("Blocked")
  auditLogsAsActor        AuditLog[]            @relation("AuditActor")
  auditLogsAsTarget       AuditLog[]            @relation("AuditTarget")
  refreshTokens           RefreshToken[]
  paymentOrders           PaymentOrder[]
  paymentRecords          PaymentRecord[]
  mobileDevices           MobileDevice[]
  claimedOffers           ClaimedOffer[]

  @@index([email])
  @@index([phone])
  @@index([locationId])
  @@index([provider, providerId])
  @@index([referralCode])
  @@index([referredBy])
  @@map("users")
}

model OTP {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String?
  phone     String?
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([email, code])
  @@index([phone, code])
  @@map("otps")
}

model Category {
  id              String               @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  slug            String
  icon            String?
  image           String?
  description     String?
  metaTitle       String?
  metaDescription String?
  order           Int                  @default(0)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  adPostingPrice  Float?
  ads             Ad[]
  banners         Banner[]
  subcategories   Subcategory[]
  offers          Offer[]
  clusters        AdCluster[]
  searchPatterns  SearchQueryPattern[]
  specifications  Specification[]

  @@unique([slug])
  @@map("categories")
}

model Subcategory {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  slug            String
  description     String?
  metaTitle       String?
  metaDescription String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  categoryId      String   @db.ObjectId
  ads             Ad[]
  category        Category @relation(fields: [categoryId], references: [id])
  specifications  Specification[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@map("subcategories")
}

model Location {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String
  state          String?
  city           String?
  pincode        String?
  latitude       Float?
  longitude      Float?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  neighbourhood  String?
  ads            Ad[]
  banners        Banner[]
  users          User[]
  clusters       AdCluster[]
  searchPatterns SearchQueryPattern[]

  @@unique([slug])
  @@index([state, city])
  @@index([state]) // For state-wise queries
  @@index([city]) // For city-wise queries
  @@index([neighbourhood]) // For local area queries
  @@index([name]) // For alphabetical sorting and search
  @@map("locations")
}

model Ad {
  id               String              @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  slug             String?
  description      String
  price            Float
  originalPrice    Float?
  discount         Float?
  condition        String?
  images           String[]
  status           AdStatus            @default(PENDING)
  isPremium        Boolean             @default(false)
  premiumType      PremiumType?
  premiumExpiresAt DateTime?
  views            Int                 @default(0)
  featuredAt       DateTime?
  bumpedAt         DateTime?
  postedAt         DateTime? // When ad was actually posted (after approval)
  expiresAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  userId           String              @db.ObjectId
  categoryId       String              @db.ObjectId
  subcategoryId    String?             @db.ObjectId
  locationId       String?             @db.ObjectId
  isUrgent         Boolean             @default(false)
  attributes       Json?
  state            String?
  city             String?
  neighbourhood    String?
  exactLocation    String?
  moderationStatus String?             @default("pending")
  moderationFlags  Json?
  rejectionReason  String?
  autoRejected     Boolean             @default(false)
  // Package type used for ranking/visibility (string enum; NEVER send numbers from code)
  // NORMAL = free ads, MAX_VISIBILITY = Basic, SELLER_PLUS = Pro, SELLER_PRIME = Enterprise
  packageType      BusinessPackageType @default(NORMAL)
  lastShownAt      DateTime? // For rotation fairness
  category         Category            @relation(fields: [categoryId], references: [id])
  location         Location?           @relation(fields: [locationId], references: [id])
  subcategory      Subcategory?        @relation(fields: [subcategoryId], references: [id])
  user             User                @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adPostingOrders  AdPostingOrder[]
  chatRooms        ChatRoom[]
  favorites        Favorite[]
  premiumOrders    PremiumOrder[]
  contactRequests  ContactRequest[]
  specificationValues AdSpecificationValue[]
  specifications    Specification[]

  @@index([userId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([locationId])
  @@index([status])
  @@index([packageType])
  @@index([lastShownAt])
  @@index([isPremium])
  @@index([createdAt])
  @@index([featuredAt])
  @@index([bumpedAt])
  @@index([expiresAt])
  @@index([slug])
  @@index([status, createdAt])
  @@index([status, isPremium, createdAt])
  @@index([categoryId, status, createdAt])
  @@index([locationId, status, createdAt])
  @@index([status, expiresAt, createdAt])
  @@index([isPremium, premiumType, createdAt])
  @@index([postedAt])
  @@index([status, postedAt])
  @@index([status, expiresAt, postedAt])
  @@index([city])
  @@index([state, city])
  @@index([state])
  @@index([categoryId, subcategoryId, slug])
  @@map("ads")
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  userId    String   @db.ObjectId
  adId      String   @db.ObjectId
  ad        Ad       @relation(fields: [adId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, adId])
  @@index([userId])
  @@map("favorites")
}

model PremiumOrder {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  type              PremiumType
  amount            Float
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String      @default("pending")
  expiresAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  userId            String      @db.ObjectId
  adId              String      @db.ObjectId
  ad                Ad          @relation(fields: [adId], references: [id])
  user              User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([status])
  @@map("premium_orders")
}

model AdPostingOrder {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  amount            Float
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String   @default("pending")
  adData            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            String   @db.ObjectId
  adId              String?  @db.ObjectId
  ad                Ad?      @relation(fields: [adId], references: [id])
  user              User     @relation(fields: [userId], references: [id])

  @@unique([razorpayOrderId])
  @@index([userId])
  @@index([status])
  @@map("ad_posting_orders")
}

model PaymentOrder {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  orderId      String    @unique
  userId       String    @db.ObjectId
  amount       Int // Amount in paise
  currency     String    @default("INR")
  status       String    @default("created") // created, paid, verified, activated, refunded, failed, cancelled
  paymentId    String?
  signature    String?
  refundId     String?
  refundAmount Int?
  notes        String? // JSON string for additional notes
  isTestOrder  Boolean   @default(false)
  paidAt       DateTime?
  verifiedAt   DateTime?
  activatedAt  DateTime?
  refundedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_orders")
}

model PaymentRecord {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  paymentId   String    @unique // Razorpay payment ID
  orderId     String // Razorpay order ID
  userId      String    @db.ObjectId
  amount      Int // Amount in paise
  currency    String    @default("INR")
  status      String    @default("paid") // paid, refunded, failed
  purpose     String // ad_promotion, membership, business_package, ad_posting
  referenceId String? // adId, packageId, etc.
  metadata    String? // JSON string for additional data
  paidAt      DateTime  @default(now())
  refundedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([orderId, paymentId]) // Prevent duplicate payments
  @@index([userId])
  @@index([purpose])
  @@index([referenceId])
  @@index([status])
  @@index([paidAt])
  @@map("payment_records")
}

model ChatRoom {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user1Id   String        @db.ObjectId
  user2Id   String        @db.ObjectId
  adId      String        @db.ObjectId
  messages  ChatMessage[]
  ad        Ad            @relation(fields: [adId], references: [id])
  user1     User          @relation("User1Rooms", fields: [user1Id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user2     User          @relation("User2Rooms", fields: [user2Id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user1Id, user2Id, adId])
  @@index([user1Id])
  @@index([user2Id])
  @@index([adId])
  @@map("chat_rooms")
}

model ChatMessage {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  content    String
  type       ChatMessageType @default(TEXT)
  imageUrl   String?
  isRead     Boolean         @default(false)
  createdAt  DateTime        @default(now())
  senderId   String          @db.ObjectId
  receiverId String          @db.ObjectId
  roomId     String          @db.ObjectId
  receiver   User            @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  room       ChatRoom        @relation(fields: [roomId], references: [id])
  sender     User            @relation("SenderMessages", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([roomId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@map("chat_messages")
}

model PremiumSettings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([key])
  @@map("premium_settings")
}

model Banner {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  image      String
  link       String?
  position   String
  categoryId String?   @db.ObjectId
  locationId String?   @db.ObjectId
  isActive   Boolean   @default(true)
  order      Int       @default(0)
  clicks     Int       @default(0)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category? @relation(fields: [categoryId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])

  @@index([position])
  @@index([isActive])
  @@index([categoryId])
  @@map("banners")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model InterstitialAd {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  image     String
  link      String?
  position  String
  isActive  Boolean   @default(true)
  frequency Int       @default(1)
  startDate DateTime?
  endDate   DateTime?
  views     Int       @default(0)
  clicks    Int       @default(0)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  height    Int?
  width     Int?

  @@index([position])
  @@index([isActive])
  @@index([isActive, position])
  @@map("interstitial_ads")
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  endpoint  String
  keys      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

model Wallet {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  balance      Float               @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  userId       String              @db.ObjectId
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]

  @@unique([userId])
  @@map("wallets")
}

model WalletTransaction {
  id          String                  @id @default(auto()) @map("_id") @db.ObjectId
  type        WalletTransactionType
  amount      Float
  status      WalletTransactionStatus @default(COMPLETED)
  description String?
  referenceId String?
  metadata    String?
  createdAt   DateTime                @default(now())
  walletId    String                  @db.ObjectId
  wallet      Wallet                  @relation(fields: [walletId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Referral {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  referralCode   String
  referredUserId String
  rewardAmount   Float     @default(0)
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  referrerId     String    @db.ObjectId
  referrer       User      @relation("Referrer", fields: [referrerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([referredUserId])
  @@index([referrerId])
  @@index([referralCode])
  @@index([status])
  @@map("referrals")
}

model BusinessPackage {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  userId            String              @db.ObjectId
  packageType       BusinessPackageType
  amount            Float
  duration          Int                 @default(30)
  maxAds            Int                 @default(0)
  premiumSlotsTotal Int                 @default(0)
  premiumSlotsUsed  Int                 @default(0)
  totalAdsAllowed   Int                 @default(0)
  adsUsed           Int                 @default(0)
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String              @default("pending")
  startDate         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([packageType])
  @@index([razorpayOrderId])
  @@index([status])
  @@index([expiresAt])
  @@map("business_packages")
}

model UserBusinessPackage {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  userId            String              @db.ObjectId
  packageType       BusinessPackageType
  amount            Float
  purchaseTime      DateTime            @default(now())
  expiresAt         DateTime?
  totalAds          Int                 @default(0)
  usedAds           Int                 @default(0)
  allowedCategories String[]            @default([]) // Array of category IDs or slugs
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String              @default("active") // active, exhausted, expired
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([packageType])
  @@index([status])
  @@index([expiresAt])
  @@index([purchaseTime])
  @@index([userId, status])
  @@index([userId, expiresAt])
  @@map("user_business_packages")
}

model ExtraAdSlot {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @db.ObjectId
  quantity          Int       @default(1)
  amount            Float
  totalAmount       Float
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String    @default("pending")
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([status])
  @@index([expiresAt])
  @@map("extra_ad_slots")
}

enum UserRole {
  USER
  ADMIN
}

enum AdStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
  EXPIRED
  INACTIVE
  DISABLED
}

enum PremiumType {
  TOP
  FEATURED
  BUMP_UP
}

enum BusinessPackageType {
  NORMAL
  MAX_VISIBILITY
  SELLER_PLUS
  SELLER_PRIME
}

enum ChatMessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model SearchQuery {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  query     String
  userId    String?
  userEmail String?
  category  String?
  location  String?
  filters   Json?
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userEmail])
  @@index([processed])
  @@index([createdAt])
  @@map("search_queries")
}

model SearchAlertSettings {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  enabled            Boolean  @default(true)
  maxEmailsPerUser   Int      @default(5)
  checkIntervalHours Int      @default(24)
  emailSubject       String   @default("New products matching your search!")
  emailBody          String   @default("<p>Hi there!</p><p>We found some products matching your recent search: <strong>{{query}}</strong></p>{{products}}<p>Happy shopping!</p>")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("search_alert_settings")
}

model AuthPageSettings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  page            String
  title           String
  subtitle        String
  tagline         String?
  imageUrl        String?
  backgroundColor String   @default("#1e293b")
  stats           Json?
  features        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([page])
  @@map("auth_page_settings")
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @db.ObjectId
  followingId String   @db.ObjectId
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model ContactRequest {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  requesterId  String               @db.ObjectId
  sellerId     String               @db.ObjectId
  adId         String?              @db.ObjectId
  status       ContactRequestStatus @default(PENDING)
  message      String?
  consentGiven Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  approvedAt   DateTime?
  rejectedAt   DateTime?

  requester User @relation("ContactRequester", fields: [requesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seller    User @relation("ContactSeller", fields: [sellerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ad        Ad?  @relation(fields: [adId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([requesterId, sellerId, adId])
  @@index([requesterId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("contact_requests")
}

enum ContactRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Block {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  blockerId String   @db.ObjectId
  blockedId String   @db.ObjectId
  reason    String?
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId   String   @db.ObjectId
  targetId  String?  @db.ObjectId
  action    String
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor  User  @relation("AuditActor", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  target User? @relation("AuditTarget", fields: [targetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([actorId])
  @@index([targetId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  token     String
  expiresAt DateTime
  revoked   Boolean   @default(false)
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([token])
  @@index([userId])
  @@index([userId, token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model MobileDevice {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  deviceId           String    @unique
  userId             String    @db.ObjectId
  deviceType         String // 'ios' or 'android'
  deviceName         String?
  osVersion          String?
  appVersion         String?
  fcmToken           String? // Firebase Cloud Messaging token for Android
  apnsToken          String? // Apple Push Notification Service token for iOS
  latitude           Float?
  longitude          Float?
  locationAccuracy   Float?
  locationAddress    String?
  lastLocationUpdate DateTime?
  lastActiveAt       DateTime  @default(now())
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([isActive])
  @@index([lastActiveAt])
  @@map("mobile_devices")
}

model Offer {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  title              String
  description        String?
  type               String // 'premium', 'discount', 'bonus', etc.
  discountPercent    Float?
  discountAmount     Float?
  categoryId         String?   @db.ObjectId
  imageUrl           String?
  termsAndConditions String?
  isActive           Boolean   @default(true)
  priority           Int       @default(0)
  maxClaimsPerUser   Int?
  totalClaims        Int       @default(0)
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  claimedOffers ClaimedOffer[]

  @@index([categoryId])
  @@index([type])
  @@index([isActive])
  @@index([expiresAt])
  @@index([priority])
  @@map("offers")
}

model ClaimedOffer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  offerId   String   @db.ObjectId
  claimedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, offerId])
  @@index([userId])
  @@index([offerId])
  @@index([claimedAt])
  @@map("claimed_offers")
}

// Search Intelligence & Clustering System Models

model AdCluster {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  clusterKey      String   @unique // Unique identifier for the cluster (e.g., "cars-kochi-under-5lakh")
  clusterType     String // 'category', 'location', 'price', 'attribute', 'intent', 'combined'
  level           Int // 1=Category, 2=Location, 3=Attributes, 4=Intent
  categoryId      String?  @db.ObjectId
  locationId      String?  @db.ObjectId
  state           String?
  city            String?
  minPrice        Float?
  maxPrice        Float?
  attributes      Json? // Category-specific attributes (brand, model, year, etc.)
  intent          String? // 'buy', 'sell', 'price', 'location', 'urgency'
  adIds           String[] // Array of ad IDs in this cluster
  adCount         Int      @default(0)
  searchQueries   String[] // Common search queries that match this cluster
  popularityScore Float    @default(0) // Based on views, searches, clicks
  lastUpdated     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category       Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  location       Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  lists          AutoList[]
  searchPatterns SearchQueryPattern[]

  @@index([clusterType])
  @@index([level])
  @@index([categoryId])
  @@index([locationId])
  @@index([state, city])
  @@index([popularityScore])
  @@index([lastUpdated])
  @@map("ad_clusters")
}

model AutoList {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  slug            String   @unique // SEO-friendly URL slug
  title           String // SEO title
  metaTitle       String // Full SEO meta title
  metaDescription String // SEO meta description
  description     String? // List description
  clusterId       String   @db.ObjectId
  adIds           String[] // Current ad IDs in this list (auto-updated)
  adCount         Int      @default(0)
  keywords        String[] // SEO keywords
  searchVolume    Int      @default(0) // Estimated search volume
  isActive        Boolean  @default(true)
  priority        Int      @default(0) // Higher priority = more important
  lastUpdated     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cluster AdCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clusterId])
  @@index([isActive])
  @@index([priority])
  @@index([searchVolume])
  @@index([lastUpdated])
  @@map("auto_lists")
}

model SearchQueryPattern {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  pattern         String // Search pattern (e.g., "car under 5 lakh")
  normalizedQuery String // Normalized version
  categoryId      String?  @db.ObjectId
  locationId      String?  @db.ObjectId
  priceIntent     String? // 'under', 'below', 'cheap', 'budget', 'affordable'
  locationIntent  String? // 'near me', 'in [city]', 'kerala', etc.
  searchCount     Int      @default(0) // How many times this query was searched
  clusterId       String?  @db.ObjectId
  lastSearched    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  location Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  cluster  AdCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([pattern])
  @@index([normalizedQuery])
  @@index([categoryId])
  @@index([locationId])
  @@index([searchCount])
  @@index([lastSearched])
  @@map("search_query_patterns")
}

model Specification {
  id            String                @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  label         String
  type          String                 // 'text', 'number', 'select', 'multiselect'
  required      Boolean                @default(false)
  placeholder   String?
  order         Int                    @default(0)
  isActive      Boolean                @default(true)
  adId          String?                @db.ObjectId // Product-specific specification
  categoryId    String?                @db.ObjectId // Optional: for default suggestions
  subcategoryId String?                @db.ObjectId // Optional: for default suggestions
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  ad            Ad?                    @relation(fields: [adId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  category      Category?              @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subcategory    Subcategory?          @relation(fields: [subcategoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  options        SpecificationOption[]
  values         AdSpecificationValue[]

  @@index([adId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([isActive])
  @@map("specifications")
}

model SpecificationOption {
  id             String                @id @default(auto()) @map("_id") @db.ObjectId
  value          String
  label          String?
  order          Int                    @default(0)
  isActive       Boolean                @default(true)
  specificationId String                @db.ObjectId
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  specification  Specification          @relation(fields: [specificationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  values         AdSpecificationValue[]

  @@index([specificationId])
  @@index([isActive])
  @@map("specification_options")
}

model AdSpecificationValue {
  id                String                @id @default(auto()) @map("_id") @db.ObjectId
  value             String
  specificationId   String                @db.ObjectId
  optionId          String?               @db.ObjectId
  adId              String?               @db.ObjectId
  isCustom          Boolean               @default(false) // true if user typed a new value
  usageCount        Int                   @default(1) // Track how many times this value is used
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  specification     Specification         @relation(fields: [specificationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  option            SpecificationOption?  @relation(fields: [optionId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  ad                Ad?                   @relation(fields: [adId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([specificationId])
  @@index([optionId])
  @@index([adId])
  @@index([value])
  @@index([isCustom])
  @@map("ad_specification_values")
}
