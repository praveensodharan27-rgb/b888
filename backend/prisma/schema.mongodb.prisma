// MongoDB Prisma Schema
// This schema is compatible with MongoDB
// All models maintain the same field structure as PostgreSQL version

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  email             String?
  phone             String?
  password          String?
  name              String
  avatar            String?
  bio               String?
  tags              String[]            @default([])
  showPhone         Boolean            @default(true)
  isVerified        Boolean            @default(false)
  role              UserRole           @default(USER)
  freeAdsUsed       Int                @default(0)  // Historical tracking (lifetime)
  freeAdsRemaining   Int                @default(2)  // Monthly free ads remaining (resets monthly)
  freeAdsUsedThisMonth Int              @default(0)  // Free ads used in current month
  lastFreeAdsResetDate DateTime?        // Last date when free ads were reset
  membershipActive  Boolean            @default(false)
  membershipType    String?            // PREMIUM, BASIC, etc.
  membershipExpiresAt DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  provider          String?
  providerId        String?
  referralCode      String?
  referredBy        String?            @db.ObjectId
  isDeactivated     Boolean            @default(false)
  deactivatedAt     DateTime?
  tokenInvalidatedAt DateTime?
  locationId        String?            @db.ObjectId
  location          Location?          @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ads               Ad[]
  adPostingOrders   AdPostingOrder[]
  receivedMessages  ChatMessage[]      @relation("ReceiverMessages")
  sentMessages      ChatMessage[]      @relation("SenderMessages")
  chatRooms         ChatRoom[]         @relation("User1Rooms")
  chatRooms2        ChatRoom[]         @relation("User2Rooms")
  favorites         Favorite[]
  notifications     Notification[]
  otpCodes          OTP[]
  premiumOrders     PremiumOrder[]
  pushSubscriptions PushSubscription[]
  referrals         Referral[]         @relation("Referrer")
  referredByUser    User?              @relation("ReferredBy", fields: [referredBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referredUsers     User[]             @relation("ReferredBy")
  wallet            Wallet?
  businessPackages  BusinessPackage[]
  userBusinessPackages UserBusinessPackage[]
  extraAdSlots      ExtraAdSlot[]
  followers         Follow[]           @relation("Following")
  following         Follow[]           @relation("Follower")
  contactRequestsSent     ContactRequest[] @relation("ContactRequester")
  contactRequestsReceived ContactRequest[] @relation("ContactSeller")
  blockedUsers      Block[]            @relation("Blocker")
  blockedBy         Block[]            @relation("Blocked")
  auditLogsAsActor  AuditLog[]         @relation("AuditActor")
  auditLogsAsTarget AuditLog[]         @relation("AuditTarget")
  refreshTokens     RefreshToken[]
  paymentOrders     PaymentOrder[]
  paymentRecords    PaymentRecord[]
  creditTransactions CreditTransaction[]
  notificationHistory NotificationHistory[]

  // Promotion credits: balance (current), lifetime used for reporting
  creditsBalance    Int                 @default(0)
  creditsUsed       Int                 @default(0)

  // AI Sales Assistant (Business Package): reply when seller is offline / not viewing chat
  aiChatEnabled     Boolean             @default(false)

  // My Business (one business per user for now)
  business         Business?

  @@index([email])
  @@index([phone])
  @@index([locationId])
  @@index([provider, providerId])
  @@index([referralCode])
  @@index([referredBy])
  @@map("users")
}

// My Business – user's own business profile (one per user for now; scalable for multiple later)
model Business {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @unique @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName  String
  slug          String    @unique
  category      String
  description   String?
  phone         String
  whatsapp      String?
  email         String?
  website       String?
  address       String?
  state         String?
  city          String
  pincode       String?
  mapLocation   Json?     // { lat, lng }
  logo          String?
  coverImage    String?
  gallery       String[]  @default([])
  services      Json?     // array of { name, price, description, image }
  workingHours  Json?     // { monday: { open, close }, ... }
  socialLinks   Json?     // { facebook, instagram, youtube }
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([city])
  @@index([category])
  @@index([isActive])
  @@map("businesses")
}

model OTP {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  email           String?
  phone           String?
  hash            String    // bcrypt hash of OTP (never store plaintext)
  expiresAt       DateTime
  used            Boolean   @default(false)
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime? // lockout after max failed attempts
  createdAt       DateTime  @default(now())
  userId          String?   @db.ObjectId
  user            User?     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([email])
  @@index([phone])
  @@index([email, createdAt])
  @@index([phone, createdAt])
  @@map("otps")
}

model Category {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String
  icon           String?
  image          String?
  description    String?
  order          Int           @default(0)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  adPostingPrice Float?
  ads            Ad[]
  banners        Banner[]
  subcategories  Subcategory[]

  @@unique([slug])
  @@map("categories")
}

model Subcategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  categoryId  String   @db.ObjectId
  ads         Ad[]
  category    Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@map("subcategories")
}

model Location {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String
  state         String?
  city          String?
  pincode       String?
  latitude      Float?
  longitude     Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  neighbourhood String?
  ads           Ad[]
  banners       Banner[]
  users         User[]

  @@unique([slug])
  @@index([state, city])
  @@map("locations")
}

model Ad {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String
  price            Float
  originalPrice    Float?
  discount         Float?
  condition        String?
  images           String[]
  status           AdStatus         @default(PENDING)
  isPremium        Boolean          @default(false)
  premiumType      PremiumType?
  premiumExpiresAt DateTime?
  views            Int              @default(0)
  featuredAt       DateTime?
  bumpedAt         DateTime?
  expiresAt        DateTime?
  postedAt         DateTime?        // When ad went live (approved)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  userId           String           @db.ObjectId
  categoryId       String           @db.ObjectId
  subcategoryId    String?          @db.ObjectId
  locationId        String?          @db.ObjectId
  isUrgent         Boolean          @default(false)
  attributes       Json?
  state            String?
  city             String?
  slug             String?   // SEO: /{stateSlug}/{citySlug}/{categorySlug}/{slug}
  stateSlug        String?   // slugify(state) for path lookup
  citySlug         String?   // slugify(city) for path lookup
  categorySlug     String?   // category.slug for path lookup
  neighbourhood    String?
  exactLocation    String?
  moderationStatus String?          @default("pending")
  moderationFlags  Json?
  rejectionReason  String?
  autoRejected     Boolean          @default(false)
  // Package type used for ranking/visibility (string enum; NEVER send numbers from code)
  // NORMAL = free ads, MAX_VISIBILITY = Basic, SELLER_PLUS = Pro, SELLER_PRIME = Enterprise
  packageType      BusinessPackageType @default(NORMAL)
  lastShownAt      DateTime?        // For rotation fairness
  // Promotion (credit-based): TOP = top section, FEATURED = pin 7 days, BUMP_UP = move to top every 24h
  promotionType    PremiumType?     // TOP | FEATURED | BUMP_UP (when isPremium true)
  promotionStartAt DateTime?        // When current promotion started
  lastBumpedAt     DateTime?        // Last bump time (for 24h reset)
  boostCount       Int              @default(0) // Number of bumps used (lifetime or current period)
  // Ranking system fields
  rankingScore     Int              @default(10) // Precomputed ranking score for optimal sorting
  planType         String?          @default("FREE") // FREE | STARTER | PROFESSIONAL | ENTERPRISE
  planPriority     Int              @default(10) // Plan base score
  isTopAdActive    Boolean          @default(false) // Top ad promotion active
  isFeaturedActive Boolean          @default(false) // Featured ad promotion active
  isBumpActive     Boolean          @default(false) // Bump promotion active
  latitude         Float?           // Geo-location latitude
  longitude        Float?           // Geo-location longitude
  adExpiryDate     DateTime?        // Ad expiry timestamp
  lastExpiryNotificationSent DateTime? // Track when last expiry notification was sent
  category         Category         @relation(fields: [categoryId], references: [id])
  location         Location?        @relation(fields: [locationId], references: [id])
  subcategory      Subcategory?     @relation(fields: [subcategoryId], references: [id])
  user             User             @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adPostingOrders  AdPostingOrder[]
  chatRooms        ChatRoom[]
  favorites        Favorite[]
  premiumOrders    PremiumOrder[]
  contactRequests  ContactRequest[]

  @@index([userId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([locationId])
  @@index([status])
  @@index([isPremium])
  @@index([createdAt])
  @@index([packageType])
  @@index([lastShownAt])
  @@index([featuredAt])
  @@index([bumpedAt])
  @@index([expiresAt])
  @@index([status, createdAt])
  @@index([status, isPremium, createdAt])
  @@index([categoryId, status, createdAt])
  @@index([locationId, status, createdAt])
  @@index([status, expiresAt, createdAt])
  @@index([isPremium, premiumType, createdAt])
  @@index([city])
  @@index([state, city])
  @@index([state])
  @@index([slug])
  @@index([stateSlug])
  @@index([citySlug])
  @@index([categorySlug])
  @@index([stateSlug, citySlug, categorySlug, slug])
  @@index([rankingScore])
  @@index([planPriority])
  @@index([isTopAdActive])
  @@index([isFeaturedActive])
  @@index([adExpiryDate])
  @@index([rankingScore, createdAt])
  @@map("ads")
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  userId    String   @db.ObjectId
  adId      String   @db.ObjectId
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, adId])
  @@index([userId])
  @@map("favorites")
}

model PremiumOrder {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  type              PremiumType
  amount            Float
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String      @default("pending")
  expiresAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  userId            String      @db.ObjectId
  adId              String      @db.ObjectId
  ad                Ad          @relation(fields: [adId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user              User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([status])
  @@map("premium_orders")
}

model AdPostingOrder {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  amount            Float
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String   @default("pending")
  adData            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            String   @db.ObjectId
  adId              String?  @db.ObjectId
  ad                Ad?      @relation(fields: [adId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user              User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([razorpayOrderId])
  @@index([userId])
  @@index([status])
  @@map("ad_posting_orders")
}

model PaymentOrder {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId           String   @unique
  userId            String   @db.ObjectId
  amount            Int      // Amount in paise
  currency          String   @default("INR")
  status            String   @default("created") // created, paid, verified, activated, refunded, failed, cancelled
  paymentId         String?
  signature         String?
  refundId          String?
  refundAmount      Int?
  notes             String?  // JSON string for additional notes
  isTestOrder       Boolean  @default(false)
  paidAt            DateTime?
  verifiedAt        DateTime?
  activatedAt       DateTime?
  refundedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_orders")
}

model PaymentRecord {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  paymentId         String   @unique // Razorpay payment ID
  orderId           String   // Razorpay order ID
  userId            String   @db.ObjectId
  amount            Int      // Amount in paise
  currency          String   @default("INR")
  status            String   @default("paid") // paid, refunded, failed
  purpose           String   // ad_promotion, membership, business_package, ad_posting
  referenceId       String?  // adId, packageId, etc.
  metadata          String?  // JSON string for additional data
  paidAt            DateTime @default(now())
  refundedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([orderId, paymentId]) // Prevent duplicate payments
  @@index([userId])
  @@index([purpose])
  @@index([referenceId])
  @@index([status])
  @@index([paidAt])
  @@map("payment_records")
}

model ChatRoom {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  user1Id              String        @db.ObjectId
  user2Id              String        @db.ObjectId
  adId                 String        @db.ObjectId
  lastSellerMessageAt  DateTime?     // Human override: no AI reply for 30 min after this
  messages             ChatMessage[]
  ad                   Ad            @relation(fields: [adId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user1                User          @relation("User1Rooms", fields: [user1Id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user2                User          @relation("User2Rooms", fields: [user2Id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user1Id, user2Id, adId])
  @@index([user1Id])
  @@index([user2Id])
  @@index([adId])
  @@map("chat_rooms")
}

model ChatMessage {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  content    String
  type       ChatMessageType @default(TEXT)
  imageUrl   String?
  isRead     Boolean         @default(false)
  isAI       Boolean         @default(false)
  createdAt  DateTime        @default(now())
  senderId   String          @db.ObjectId
  receiverId String          @db.ObjectId
  roomId     String          @db.ObjectId
  receiver   User            @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  room       ChatRoom        @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sender     User            @relation("SenderMessages", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([roomId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@map("chat_messages")
}

model PremiumSettings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([key])
  @@map("premium_settings")
}

// Audit log for ad ranking/rotation (optional; for analytics and fairness)
model AdRankLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  adId         String   @db.ObjectId
  context      String   // home, category, search, etc.
  contextId    String?  // categoryId, locationId, etc.
  planTier     String   // SELLER_PRIME, SELLER_PLUS, MAX_VISIBILITY, NORMAL
  position     Int      // 1-based position in result
  featured     Boolean  @default(false)
  bumped       Boolean  @default(false)
  lastShownAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([adId])
  @@index([context, contextId])
  @@index([createdAt])
  @@map("ad_rank_logs")
}

model Banner {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  image      String
  link       String?
  position   String
  categoryId String?   @db.ObjectId
  locationId String?   @db.ObjectId
  isActive   Boolean   @default(true)
  order      Int       @default(0)
  clicks     Int       @default(0)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category? @relation(fields: [categoryId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])

  @@index([position])
  @@index([isActive])
  @@index([categoryId])
  @@map("banners")
}

// Free Posting Ads Card - backend-controlled, location-targeted, shown below Description on ad detail
model FreePostingPromo {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  image               String?
  title               String
  description         String?
  ctaText             String    @default("Post Free Ad")
  ctaLink             String    @default("/post-ad")
  priority            Int       @default(0)
  startDate           DateTime?
  endDate             DateTime?
  isActive            Boolean   @default(true)
  showForAllLocations Boolean   @default(false)
  targetLocations     Json?     // [{ country?, state?, city?, district? }] - empty or null = use showForAllLocations
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([isActive])
  @@index([startDate, endDate])
  @@map("free_posting_promos")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([isRead])
  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@map("notifications")
}

model InterstitialAd {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  image     String
  link      String?
  position  String
  isActive  Boolean   @default(true)
  frequency Int       @default(1)
  startDate DateTime?
  endDate   DateTime?
  views     Int       @default(0)
  clicks    Int       @default(0)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  height    Int?
  width     Int?

  @@index([position])
  @@index([isActive])
  @@index([isActive, position])
  @@map("interstitial_ads")
}

// Sponsored ads - location-targeted, admin-managed, shown in ad detail sidebar
model SponsoredAd {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  bannerImage  String?
  bannerVideo  String?
  description  String?
  ctaType      String   @default("website") // call, whatsapp, website
  ctaLabel     String?
  redirectUrl  String?
  targetLocations String[] @default([]) // Location slugs: ["kottayam", "pala", "changanassery"]
  categorySlug String?  // Car, Job, Property etc. - optional filter
  adSize       String   @default("medium") // small, medium, large
  startDate    DateTime?
  endDate      DateTime?
  budget       Float    @default(0)
  priority     Int      @default(0) // Higher = more visibility
  status       String   @default("active") // active, paused, expired
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  lastShownAt DateTime? // For rotation fairness
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([adSize])
  @@index([priority])
  @@index([startDate, endDate])
  @@index([lastShownAt])
  @@map("sponsored_ads")
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  endpoint  String
  keys      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

model Wallet {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  balance      Float               @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  userId       String              @db.ObjectId
  user         User                @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions WalletTransaction[]

  @@unique([userId])
  @@map("wallets")
}

model WalletTransaction {
  id          String                  @id @default(auto()) @map("_id") @db.ObjectId
  type        WalletTransactionType
  amount      Float
  status      WalletTransactionStatus @default(COMPLETED)
  description String?
  referenceId String?
  metadata    String?
  createdAt   DateTime                @default(now())
  walletId    String                  @db.ObjectId
  wallet      Wallet                  @relation(fields: [walletId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("wallet_transactions")
}

// Promotion credits: purchase + spend (TOP Ad, Featured, Bump Up)
model CreditTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  amount      Int      // Positive = credit, negative = debit
  balanceAfter Int?    // Balance after this transaction (for audit)
  type        CreditTransactionType
  referenceId String?  // adId or orderId
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceId])
  @@map("credit_transactions")
}

enum CreditTransactionType {
  PURCHASE      // Bought credits
  TOP_AD        // Spent on TOP promotion
  FEATURED_AD   // Spent on Featured promotion
  BUMP_UP       // Spent on Bump Up
  REFUND        // Refunded
  ADMIN_CREDIT  // Admin granted
  ADMIN_DEBIT   // Admin deducted
}

model Referral {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  referralCode   String
  referredUserId String
  rewardAmount   Float     @default(0)
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  referrerId     String    @db.ObjectId
  referrer       User      @relation("Referrer", fields: [referrerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([referredUserId])
  @@index([referrerId])
  @@index([referralCode])
  @@index([status])
  @@map("referrals")
}

model BusinessPackage {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  userId            String              @db.ObjectId
  packageType       BusinessPackageType
  amount            Float
  duration          Int                 @default(30)
  maxAds            Int                 @default(0)
  premiumSlotsTotal Int                 @default(0)
  premiumSlotsUsed  Int                 @default(0)
  totalAdsAllowed   Int                 @default(0)
  adsUsed           Int                 @default(0)
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String              @default("pending")
  startDate         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([packageType])
  @@index([razorpayOrderId])
  @@index([status])
  @@index([expiresAt])
  @@map("business_packages")
}

model UserBusinessPackage {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  userId            String              @db.ObjectId
  packageType       BusinessPackageType
  amount            Float
  purchaseTime      DateTime            @default(now())
  expiresAt         DateTime?
  totalAds          Int                 @default(0)
  usedAds           Int                 @default(0)
  allowedCategories String[]            @default([])  // Array of category IDs or slugs
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String              @default("active")  // active, exhausted, expired
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([packageType])
  @@index([status])
  @@index([expiresAt])
  @@index([purchaseTime])
  @@index([userId, status])
  @@index([userId, expiresAt])
  @@map("user_business_packages")
}

model ExtraAdSlot {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  userId            String              @db.ObjectId
  quantity          Int                 @default(1)
  amount            Float
  totalAmount       Float
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String              @default("pending")
  expiresAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([status])
  @@index([expiresAt])
  @@map("extra_ad_slots")
}

enum UserRole {
  USER
  ADMIN
}

enum AdStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
  EXPIRED
  INACTIVE
  DISABLED
}

enum PremiumType {
  TOP
  FEATURED
  BUMP_UP
}

enum BusinessPackageType {
  NORMAL
  MAX_VISIBILITY
  SELLER_PLUS
  SELLER_PRIME
}

enum ChatMessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model SearchQuery {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  query     String
  userId    String?
  userEmail String?
  category  String?
  location  String?
  filters   Json?
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([userEmail])
  @@index([processed])
  @@index([createdAt])
  @@map("search_queries")
}

model SearchAlertSettings {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  enabled            Boolean  @default(true)
  maxEmailsPerUser   Int      @default(5)
  checkIntervalHours Int      @default(24)
  emailSubject       String   @default("New products matching your search!")
  emailBody          String   @default("<p>Hi there!</p><p>We found some products matching your recent search: <strong>{{query}}</strong></p>{{products}}<p>Happy shopping!</p>")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@map("search_alert_settings")
}

model AuthPageSettings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  page            String
  title           String
  subtitle        String
  tagline         String?
  imageUrl        String?
  backgroundColor String   @default("#1e293b")
  stats           Json?
  features        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([page])
  @@map("auth_page_settings")
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @db.ObjectId
  followingId String   @db.ObjectId
  createdAt   DateTime @default(now())

  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model ContactRequest {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  requesterId  String   @db.ObjectId
  sellerId     String   @db.ObjectId
  adId         String?  @db.ObjectId
  status       ContactRequestStatus @default(PENDING)
  message      String?
  consentGiven Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  approvedAt   DateTime?
  rejectedAt   DateTime?

  requester    User     @relation("ContactRequester", fields: [requesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seller       User     @relation("ContactSeller", fields: [sellerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ad           Ad?      @relation(fields: [adId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([requesterId, sellerId, adId])
  @@index([requesterId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("contact_requests")
}

enum ContactRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Block {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  blockerId  String   @db.ObjectId
  blockedId  String   @db.ObjectId
  reason     String?
  createdAt  DateTime @default(now())

  blocker    User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  blocked    User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId   String   @db.ObjectId
  targetId  String?  @db.ObjectId
  action    String
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor     User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  target    User?    @relation("AuditTarget", fields: [targetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([actorId])
  @@index([targetId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([token])
  @@index([userId])
  @@index([userId, token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ---------- India Business Directory (SEO) ----------
model DirectoryState {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    DirectoryCity[]
  businesses DirectoryBusiness[]

  @@map("directory_states")
}

model DirectoryCity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String
  stateId   String   @db.ObjectId
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  state     DirectoryState   @relation(fields: [stateId], references: [id], onDelete: Cascade)
  businesses DirectoryBusiness[]

  @@unique([stateId, slug])
  @@index([stateId])
  @@index([slug])
  @@map("directory_cities")
}

model DirectoryCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  metaTitle   String?
  metaDescription String?
  order       Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  businesses  DirectoryBusiness[]

  @@map("directory_categories")
}

model DirectoryBusiness {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String
  description   String?
  phone         String?
  email         String?
  website       String?
  address       String?
  latitude      Float?
  longitude     Float?
  openingHours  Json?
  categoryId    String   @db.ObjectId
  cityId        String   @db.ObjectId
  stateId       String   @db.ObjectId
  userId        String?  @db.ObjectId
  isVerified    Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  images        String[] @default([])
  whatsapp      String?
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  viewCount     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  category      DirectoryCategory @relation(fields: [categoryId], references: [id])
  city          DirectoryCity      @relation(fields: [cityId], references: [id])
  state         DirectoryState    @relation(fields: [stateId], references: [id])
  reviews       DirectoryReview[]

  @@unique([stateId, cityId, categoryId, slug])
  @@index([categoryId])
  @@index([cityId])
  @@index([stateId])
  @@index([slug])
  @@index([isFeatured])
  @@index([rating])
  @@map("directory_businesses")
}

model DirectoryReview {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId  String   @db.ObjectId
  userId      String?  @db.ObjectId
  authorName  String
  rating      Int
  content     String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  business    DirectoryBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([createdAt])
  @@map("directory_reviews")
}

model DirectoryBlogPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  metaTitle   String?
  metaDescription String?
  author      String?
  image       String?
  tags        String[] @default([])
  publishedAt DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
  @@map("directory_blog_posts")
}

// 301 redirects when slug is updated (e.g. business renamed). fromPath = old URL path, toPath = new URL path.
model DirectorySlugRedirect {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fromPath  String   @unique  // e.g. /kerala/ernakulam/spa/old-business-slug
  toPath    String   // e.g. /kerala/ernakulam/spa/new-business-slug
  createdAt DateTime @default(now())

  @@map("directory_slug_redirects")
}

// Notification History - Track all notifications sent to users
model NotificationHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  eventType   String   // ad_created, ad_approved, ad_rejected, ad_expiring_soon, ad_expired, package_purchased, payment_success, invoice_generated, offer_received, offer_accepted, offer_rejected
  
  // Related entities
  adId        String?  @db.ObjectId
  orderId     String?  @db.ObjectId
  invoiceId   String?  @db.ObjectId
  offerId     String?  @db.ObjectId
  
  // Delivery status
  emailSent   Boolean  @default(false)
  smsSent     Boolean  @default(false)
  emailStatus String   @default("pending") // pending, delivered, failed, bounced
  smsStatus   String   @default("pending") // pending, delivered, failed
  
  // Metadata (JSON field for additional data)
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([eventType])
  @@index([adId])
  @@index([createdAt])
  @@map("notification_history")
}

// Category/subcategory brands and models (e.g. cars, mobiles) — used for post-ad brand→model dropdown
model SubcategoryBrands {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  categorySlug     String
  subcategorySlug  String
  brands           Json     // [{ name: string, models: string[] }]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([categorySlug, subcategorySlug])
  @@index([categorySlug])
  @@index([subcategorySlug])
  @@map("subcategory_brands")
}
