# Production Environment Variables Template
# Copy this file to backend/.env and fill in your actual values
# DO NOT commit .env file to version control

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
FRONTEND_URL=https://yourdomain.com
# Used by sitemap, OG images, canonical URLs. Set at BUILD time.
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
# Set to true in production to allow indexing; false on staging.
NEXT_PUBLIC_SEO_INDEXABLE=true
BACKEND_URL=https://api.yourdomain.com

# ============================================
# Database Configuration
# ============================================
# MongoDB Connection String (NEVER commit real credentials; use placeholders only)
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/YOUR_DB?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/YOUR_DB?retryWrites=true&w=majority

# PostgreSQL (for migration only - remove after migration)
# POSTGRES_DATABASE_URL=postgresql://sellit_user:YOUR_PASSWORD@localhost:5432/sellit?schema=public

# ============================================
# JWT & Security
# ============================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@yourdomain.com

# ============================================
# SMS Configuration (Twilio - Optional)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# OTP Configuration (Enterprise)
# ============================================
OTP_EXPIRES_IN=300
OTP_RATE_LIMIT_MAX=5
OTP_RATE_WINDOW_SEC=300
OTP_MAX_FAILED_ATTEMPTS=5
OTP_LOCKOUT_MINUTES=15
OTP_BCRYPT_ROUNDS=10
OTP_JOB_RETRY_ATTEMPTS=3
OTP_JOB_RETRY_DELAY_MS=2000
OTP_WORKER_CONCURRENCY=5
APP_NAME=SellIt

# ============================================
# AWS S3 Configuration (for file uploads)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
USE_CLOUDINARY=false

# ============================================
# Cloudinary Configuration (Alternative to S3)
# ============================================
# If USE_CLOUDINARY=true, use these instead of S3
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# Payment Gateway (Razorpay)
# ============================================
# Payment Gateway Mode (set to true for mock payments in development)
PAYMENT_GATEWAY_DEV_MODE=false

# Razorpay API Keys
# Test Mode Keys (for development/testing)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_key

# Live Mode Keys (for production - uncomment when ready)
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_live_secret_key

# Razorpay Webhook Secret (for webhook verification)
# Get from: Razorpay Dashboard → Settings → Webhooks → Webhook Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_key

# ============================================
# AI Services (Optional)
# ============================================
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# ============================================
# OAuth Configuration (Google)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# OAuth Configuration (Facebook)
# ============================================
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ============================================
# Redis (Required for BullMQ OTP/notification queue)
# ============================================
REDIS_URL=redis://127.0.0.1:6379
# OTP and notifications are queued to BullMQ. Run worker: npm run worker

# ============================================
# Search Service (Meilisearch - Optional)
# ============================================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=your-meilisearch-master-key

# ============================================
# Application Settings
# ============================================
FREE_ADS_LIMIT=2
AD_POSTING_PRICE=49

# Premium Ad Pricing
PREMIUM_PRICE_TOP=299
PREMIUM_PRICE_FEATURED=199
PREMIUM_PRICE_BUMP_UP=99
PREMIUM_PRICE_URGENT=49

# Premium Ad Duration (in days)
PREMIUM_DURATION_TOP=7
PREMIUM_DURATION_FEATURED=14
PREMIUM_DURATION_BUMP_UP=1
PREMIUM_DURATION_URGENT=7

# Referral
REFERRAL_REWARD_AMOUNT=50
